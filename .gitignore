# === SENSITIVE FILES — NEVER COMMIT ===
# If you ever accidentally commit any of these, treat the secret as
# compromised, rotate it, and rewrite git history before pushing.
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
secrets.json
secrets.toml
credentials.json
*credential*
*.api-key
auth.toml

# === Build / generated ===
node_modules
/build
/.svelte-kit
/package
target/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# === User-local data ===
# Whisper models can be 3 GB
models/
# Local-only test fixtures
*.local
# Logs
*.log
logs/
# Cached transcriptions from manual testing
*.api.txt
*.api.mp3
*.api.chunks/

# === IDE / OS ===
.idea/
*.swp
*.swo
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
